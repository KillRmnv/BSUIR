<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.technical-sciences.org/ontology#"
     xml:base="http://www.technical-sciences.org/ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ns="http://www.w3.org/2003/06/sw-vocab-status/ns#"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:wot="http://xmlns.com/wot/0.1/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:doap="http://usefulinc.com/ns/doap#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#"
     xmlns:edamontology="http://edamontology.org/">
    <owl:Ontology rdf:about="http://www.technical-sciences.org/ontology">
        <owl:imports rdf:resource="http://edamontology.org"/>
        <owl:imports rdf:resource="https://w3id.org/skgo/modsci/1.0"/>
        <rdfs:comment>Ontology covering the domain of Technical Sciences including theoretical disciplines, applied disciplines, industry sectors, research objects, methods, and historical technological paradigms.</rdfs:comment>
        <rdfs:label>Technical Sciences Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.technical-sciences.org/ontology#belongsToEra -->

    <owl:ObjectProperty rdf:about="http://www.technical-sciences.org/ontology#belongsToEra">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDiscipline"/>
        <rdfs:range rdf:resource="http://www.technical-sciences.org/ontology#TechnologicalEra"/>
        <rdfs:label>belongs to era</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.technical-sciences.org/ontology#hasApplicationArea -->

    <owl:ObjectProperty rdf:about="http://www.technical-sciences.org/ontology#hasApplicationArea">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
        <rdfs:range rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"/>
        <rdfs:label>has application area</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.technical-sciences.org/ontology#partOfSystem -->

    <owl:ObjectProperty rdf:about="http://www.technical-sciences.org/ontology#partOfSystem">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"/>
        <rdfs:range rdf:resource="http://www.technical-sciences.org/ontology#SystemObject"/>
        <rdfs:label>part of system</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.technical-sciences.org/ontology#studies -->

    <owl:ObjectProperty rdf:about="http://www.technical-sciences.org/ontology#studies">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"/>
        <rdfs:range rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"/>
        <rdfs:label>studies</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.technical-sciences.org/ontology#usesMethod -->

    <owl:ObjectProperty rdf:about="http://www.technical-sciences.org/ontology#usesMethod">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"/>
        <rdfs:range rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"/>
        <rdfs:label>uses method</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.technical-sciences.org/ontology#automationLevel -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#automationLevel">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ProcessObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>automation level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#economicImpact -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#economicImpact">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>economic impact</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#endYear -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#endYear">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TechnologicalEra"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>end year</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#foundationYear -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#foundationYear">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>foundation year</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#hasDescription -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#hasDescription">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#hasName -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#hasName">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>has name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#industryRelevance -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#industryRelevance">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>industry relevance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#integrationLevel -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#integrationLevel">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#SystemObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>integration level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#materialType -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#materialType">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>material type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#mathematicalComplexity -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#mathematicalComplexity">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>mathematical complexity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#methodAccuracy -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#methodAccuracy">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>method accuracy</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#modelFidelity -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#modelFidelity">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ModelingApproach"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>model fidelity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#operatingTemperature -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#operatingTemperature">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>operating temperature</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#powerConsumption -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#powerConsumption">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>power consumption</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#practicalApplication -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#practicalApplication">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>practical application</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#processDuration -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#processDuration">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ProcessObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>process duration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#realTimeCapability -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#realTimeCapability">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ModelingApproach"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>real time capability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#resourceIntensity -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#resourceIntensity">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>resource intensity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#scaleLevel -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#scaleLevel">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>scale level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#startYear -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#startYear">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#TechnologicalEra"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>start year</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#systemComplexity -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#systemComplexity">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#SystemObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>system complexity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.technical-sciences.org/ontology#workforceSize -->

    <owl:DatatypeProperty rdf:about="http://www.technical-sciences.org/ontology#workforceSize">
        <rdfs:domain rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>workforce size</rdfs:label>
    </owl:DatatypeProperty>
    


