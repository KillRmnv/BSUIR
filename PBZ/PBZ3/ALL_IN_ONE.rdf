    <!-- http://edamontology.org/topic_0605 -->

    <rdf:Description rdf:about="http://edamontology.org/topic_0605">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
    </rdf:Description>
    


    <!-- http://edamontology.org/topic_3314 -->

    <rdf:Description rdf:about="http://edamontology.org/topic_3314">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
    </rdf:Description>
    


    <!-- http://edamontology.org/topic_3315 -->

    <rdf:Description rdf:about="http://edamontology.org/topic_3315">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
    </rdf:Description>
    


    <!-- http://edamontology.org/topic_3316 -->

    <rdf:Description rdf:about="http://edamontology.org/topic_3316">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
    </rdf:Description>
    


    <!-- http://edamontology.org/topic_3318 -->

    <rdf:Description rdf:about="http://edamontology.org/topic_3318">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
    </rdf:Description>
    


    <!-- http://sweetontology.net/phen/Phenomenon -->

    <rdf:Description rdf:about="http://sweetontology.net/phen/Phenomenon">
        <owl:equivalentClass rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"/>
    </rdf:Description>
    


    <!-- http://www.technical-sciences.org/ontology#AppliedDiscipline -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#AppliedDiscipline">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDiscipline"/>
        <rdfs:comment>Practical implementation disciplines</rdfs:comment>
        <rdfs:label>Applied Discipline</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#IndustrySector -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#IndustrySector">
        <owl:equivalentClass rdf:resource="https://w3id.org/skgo/modsci#Industry"/>
        <rdfs:comment>Industrial application domains and sectors</rdfs:comment>
        <rdfs:label>Industry Sector</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#MaterialObject -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#MaterialObject">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"/>
        <rdfs:comment>Physical material objects at micro and macro levels</rdfs:comment>
        <rdfs:label>Material Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#ModelingApproach -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#ModelingApproach">
        <owl:equivalentClass rdf:resource="https://w3id.org/skgo/modsci#ScientificMethod"/>
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"/>
        <rdfs:comment>Modeling and simulation approaches</rdfs:comment>
        <rdfs:label>Modeling Approach</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#ProcessObject -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#ProcessObject">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"/>
        <rdfs:comment>Algorithmic and procedural objects</rdfs:comment>
        <rdfs:label>Process Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#ResearchMethod -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#ResearchMethod">
        <rdfs:comment>Methods and tools for technical research</rdfs:comment>
        <rdfs:label>Research Method</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#ResearchObject -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#ResearchObject">
        <rdfs:comment>Objects of study in technical sciences</rdfs:comment>
        <rdfs:label>Research Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#SystemObject -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#SystemObject">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"/>
        <rdfs:comment>Complex system-level objects at mega level</rdfs:comment>
        <rdfs:label>System Object</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#TechnicalDevice -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#TechnicalDevice">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"/>
        <rdfs:comment>Technical devices and equipment</rdfs:comment>
        <rdfs:label>Technical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#TechnicalDiscipline -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#TechnicalDiscipline">
        <rdfs:comment>Base class for all technical and engineering disciplines</rdfs:comment>
        <rdfs:label>Technical Discipline</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#TechnologicalEra -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#TechnologicalEra">
        <rdfs:comment>Historical technological paradigms and evolutionary waves</rdfs:comment>
        <rdfs:label>Technological Era</rdfs:label>
    </owl:Class>
    


    <!-- http://www.technical-sciences.org/ontology#TheoreticalDiscipline -->

    <owl:Class rdf:about="http://www.technical-sciences.org/ontology#TheoreticalDiscipline">
        <rdfs:subClassOf rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDiscipline"/>
        <rdfs:comment>Fundamental theoretical disciplines forming the basis of technical sciences</rdfs:comment>
        <rdfs:label>Theoretical Discipline</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.technical-sciences.org/ontology#ActuatorSystem -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#ActuatorSystem">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDevice"/>
        <hasDescription>Executive mechanisms for motion control</hasDescription>
        <hasName>Actuator System</hasName>
        <operatingTemperature>-20 to 60°C</operatingTemperature>
        <powerConsumption>0.5-100 kW</powerConsumption>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#AdditiveManufacturing -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#AdditiveManufacturing">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#ProcessObject"/>
        <automationLevel>High</automationLevel>
        <hasDescription>3D printing and layer-by-layer construction</hasDescription>
        <hasName>Additive Manufacturing</hasName>
        <processDuration>Hours to days</processDuration>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#AnalyticalMethod -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#AnalyticalMethod">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"/>
        <hasDescription>Differential and integral equations for process description</hasDescription>
        <hasName>Analytical Methods</hasName>
        <methodAccuracy>Exact</methodAccuracy>
        <resourceIntensity>Low</resourceIntensity>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#AutomotiveIndustry -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#AutomotiveIndustry">
        <rdf:type rdf:resource="https://w3id.org/skgo/modsci#Industry"/>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#Biotechnology -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#Biotechnology">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"/>
        <hasDescription>Application of biological systems in engineering</hasDescription>
        <hasName>Biotechnology and Bioengineering</hasName>
        <industryRelevance>High</industryRelevance>
        <practicalApplication>Pharmaceuticals and agricultural production</practicalApplication>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#CNCMachine -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#CNCMachine">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDevice"/>
        <partOfSystem rdf:resource="http://www.technical-sciences.org/ontology#Technosphere"/>
        <hasDescription>Computer numerical control machine for precision manufacturing</hasDescription>
        <hasName>CNC Machine Tool</hasName>
        <operatingTemperature>15-35°C</operatingTemperature>
        <powerConsumption>5-50 kW</powerConsumption>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#ClimateChange -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#ClimateChange">
        <rdf:type rdf:resource="http://sweetontology.net/phen/Phenomenon"/>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#CompositeMaterials -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#CompositeMaterials">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"/>
        <hasDescription>Multi-phase materials with enhanced properties</hasDescription>
        <hasName>Composite Materials</hasName>
        <materialType>Hybrid</materialType>
        <scaleLevel>Multi-scale</scaleLevel>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#ComputationalMethod -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#ComputationalMethod">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"/>
        <hasDescription>Numerical modeling and computer simulation</hasDescription>
        <hasName>Computational Methods</hasName>
        <methodAccuracy>Medium to High</methodAccuracy>
        <resourceIntensity>Medium</resourceIntensity>
    </owl:NamedIndividual>
    


    <!-- http://www.technical-sciences.org/ontology#ControlTheory -->

    <owl:NamedIndividual rdf:about="http://www.technical-sciences.org/ontology#ControlTheory">
        <rdf:type rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"/>
