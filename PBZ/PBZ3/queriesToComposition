PREFIX ts: <http://www.technical-sciences.org/ontology#>
PREFIX edam: <http://edamontology.org/>
PREFIX modsci: <http://www.modsci.org/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?localMethod ?localLabel ?externalEntity ?externalLabel ?linkType
WHERE {
  ?localMethod a ts:ResearchMethod .
  ?localMethod rdfs:label ?localLabel .
  
  ?localMethod ?linkType ?externalEntity .
  
  OPTIONAL { ?externalEntity rdfs:label ?externalLabel }
  
  FILTER (?linkType IN (owl:sameAs, skos:exactMatch, skos:related))
}
ORDER BY ?localLabel

