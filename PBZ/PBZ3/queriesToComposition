
PREFIX ts: <http://www.technical-sciences.org/ontology#>
PREFIX edam: <http://edamontology.org/>
PREFIX modsci: <http://www.modsci.org/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?source ?method ?label ?type
WHERE {
  {
    ?method a ts:ResearchMethod .
    ?method rdfs:label ?label .
    BIND("Technical-Sciences" AS ?source)
    BIND("ResearchMethod" AS ?type)
  }
  UNION
  {

    ?method a ts:ScientificMethod .
    ?method rdfs:label ?label .
    BIND("Technical-Sciences" AS ?source)
    BIND("ScientificMethod" AS ?type)
  }
  UNION
  {
    ?method a edam:operation .
    ?method rdfs:label ?label .
    BIND("EDAM" AS ?source)
    BIND("Operation" AS ?type)
  }
}
ORDER BY ?source ?label
LIMIT 50

