PREFIX ts: <http://www.technical-sciences.org/ontology#>
PREFIX edam: <http://edamontology.org/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT ?application ?appLabel ?method ?methodLabel ?edamOp ?tool ?toolLabel
WHERE {
  ?application a ts:AppliedDiscipline .
  ?application rdfs:label ?appLabel .
  ?application ts:usesMethod ?method .
  
  ?method rdfs:label ?methodLabel .
  
  ?method owl:sameAs ?edamOp .
  
  ?tool a edam:tool .
  ?tool edam:hasFunction ?edamOp .
  ?tool rdfs:label ?toolLabel .
}
ORDER BY ?appLabel
