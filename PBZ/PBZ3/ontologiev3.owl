<?xml version="1.0" ?>
<rdf:RDF
    xmlns="http://www.technical-sciences.org/ontology#"
    xml:base="http://www.technical-sciences.org/ontology"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:xml="http://www.w3.org/XML/1998/namespace"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>

    <owl:Ontology rdf:about="http://www.technical-sciences.org/ontology">
        <rdfs:label>Technical Sciences Ontology</rdfs:label>
        <rdfs:comment
        >Ontology covering the domain of Technical Sciences including theoretical disciplines, applied disciplines, industry sectors, research objects, methods, and historical technological paradigms.</rdfs:comment>
    </owl:Ontology>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties (Relations)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:ObjectProperty
        rdf:about="http://www.technical-sciences.org/ontology#hasApplicationArea"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <rdfs:range
            rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"
        />
        <rdfs:label>has application area</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty
        rdf:about="http://www.technical-sciences.org/ontology#usesMethod"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"
        />
        <rdfs:range
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"
        />
        <rdfs:label>uses method</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty
        rdf:about="http://www.technical-sciences.org/ontology#belongsToEra"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDiscipline"
        />
        <rdfs:range
            rdf:resource="http://www.technical-sciences.org/ontology#TechnologicalEra"
        />
        <rdfs:label>belongs to era</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty
        rdf:about="http://www.technical-sciences.org/ontology#studies"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"
        />
        <rdfs:range
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"
        />
        <rdfs:label>studies</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty
        rdf:about="http://www.technical-sciences.org/ontology#partOfSystem"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"
        />
        <rdfs:range
            rdf:resource="http://www.technical-sciences.org/ontology#SystemObject"
        />
        <rdfs:label>part of system</rdfs:label>
    </owl:ObjectProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data Properties (Slots/Attributes)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- Common properties for all classes -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#hasName"
    >
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing" />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>has name</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#hasDescription"
    >
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing" />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>has description</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for TheoreticalDiscipline -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#mathematicalComplexity"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>mathematical complexity</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#foundationYear"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
        <rdfs:label>foundation year</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for AppliedDiscipline -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#industryRelevance"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>industry relevance</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#practicalApplication"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#AppliedDiscipline"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>practical application</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for IndustrySector -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#economicImpact"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>economic impact</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#workforceSize"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
        <rdfs:label>workforce size</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for MaterialObject -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#materialType"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>material type</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#scaleLevel"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>scale level</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for ProcessObject -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#processDuration"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ProcessObject"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>process duration</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#automationLevel"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ProcessObject"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>automation level</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for SystemObject -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#systemComplexity"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#SystemObject"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>system complexity</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#integrationLevel"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#SystemObject"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>integration level</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for ResearchMethod -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#methodAccuracy"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>method accuracy</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#resourceIntensity"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>resource intensity</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for TechnologicalEra -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#startYear"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TechnologicalEra"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
        <rdfs:label>start year</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#endYear"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TechnologicalEra"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer" />
        <rdfs:label>end year</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for TechnicalDevice -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#powerConsumption"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDevice"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>power consumption</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#operatingTemperature"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDevice"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>operating temperature</rdfs:label>
    </owl:DatatypeProperty>

    <!-- Properties for ModelingApproach -->
    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#modelFidelity"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ModelingApproach"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
        <rdfs:label>model fidelity</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty
        rdf:about="http://www.technical-sciences.org/ontology#realTimeCapability"
    >
        <rdfs:domain
            rdf:resource="http://www.technical-sciences.org/ontology#ModelingApproach"
        />
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean" />
        <rdfs:label>real time capability</rdfs:label>
    </owl:DatatypeProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- Class 1: TechnicalDiscipline (Top Level) -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#TechnicalDiscipline"
    >
        <rdfs:label>Technical Discipline</rdfs:label>
        <rdfs:comment
        >Base class for all technical and engineering disciplines</rdfs:comment>
    </owl:Class>

    <!-- Class 2: TheoreticalDiscipline -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDiscipline"
        />
        <rdfs:label>Theoretical Discipline</rdfs:label>
        <rdfs:comment
        >Fundamental theoretical disciplines forming the basis of technical sciences</rdfs:comment>
    </owl:Class>

    <!-- Class 3: AppliedDiscipline -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#AppliedDiscipline"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#TechnicalDiscipline"
        />
        <rdfs:label>Applied Discipline</rdfs:label>
        <rdfs:comment>Practical implementation disciplines</rdfs:comment>
    </owl:Class>

    <!-- Class 4: IndustrySector -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#IndustrySector"
    >
        <rdfs:label>Industry Sector</rdfs:label>
        <rdfs:comment>Industrial application domains and sectors</rdfs:comment>
    </owl:Class>

    <!-- Class 5: ResearchObject -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#ResearchObject"
    >
        <rdfs:label>Research Object</rdfs:label>
        <rdfs:comment>Objects of study in technical sciences</rdfs:comment>
    </owl:Class>

    <!-- Class 6: MaterialObject -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#MaterialObject"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"
        />
        <rdfs:label>Material Object</rdfs:label>
        <rdfs:comment
        >Physical material objects at micro and macro levels</rdfs:comment>
    </owl:Class>

    <!-- Class 7: ProcessObject -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#ProcessObject"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"
        />
        <rdfs:label>Process Object</rdfs:label>
        <rdfs:comment>Algorithmic and procedural objects</rdfs:comment>
    </owl:Class>

    <!-- Class 8: SystemObject -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#SystemObject"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchObject"
        />
        <rdfs:label>System Object</rdfs:label>
        <rdfs:comment>Complex system-level objects at mega level</rdfs:comment>
    </owl:Class>

    <!-- Class 9: ResearchMethod -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#ResearchMethod"
    >
        <rdfs:label>Research Method</rdfs:label>
        <rdfs:comment>Methods and tools for technical research</rdfs:comment>
    </owl:Class>

    <!-- Class 10: TechnologicalEra -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#TechnologicalEra"
    >
        <rdfs:label>Technological Era</rdfs:label>
        <rdfs:comment
        >Historical technological paradigms and evolutionary waves</rdfs:comment>
    </owl:Class>

    <!-- Class 11: TechnicalDevice (Bonus for completeness) -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#TechnicalDevice"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#MaterialObject"
        />
        <rdfs:label>Technical Device</rdfs:label>
        <rdfs:comment>Technical devices and equipment</rdfs:comment>
    </owl:Class>

    <!-- Class 12: ModelingApproach (Bonus for completeness) -->
    <owl:Class
        rdf:about="http://www.technical-sciences.org/ontology#ModelingApproach"
    >
        <rdfs:subClassOf
            rdf:resource="http://www.technical-sciences.org/ontology#ResearchMethod"
        />
        <rdfs:label>Modeling Approach</rdfs:label>
        <rdfs:comment>Modeling and simulation approaches</rdfs:comment>
    </owl:Class>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Instances of TheoreticalDiscipline (2+ instances)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:NamedIndividual
        rdf:about="http://www.technical-sciences.org/ontology#MathematicalAnalysis"
    >
        <rdf:type
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <hasName
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Mathematical Analysis</hasName>
        <hasDescription
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Foundation of mathematical methods for engineering calculations</hasDescription>
        <mathematicalComplexity
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Very High</mathematicalComplexity>
        <foundationYear
            rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
        >1687</foundationYear>
    </owl:NamedIndividual>

    <owl:NamedIndividual
        rdf:about="http://www.technical-sciences.org/ontology#TechnicalMechanics"
    >
        <rdf:type
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <hasName
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Technical Mechanics</hasName>
        <hasDescription
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Study of forces and motion in mechanical systems</hasDescription>
        <mathematicalComplexity
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >High</mathematicalComplexity>
        <foundationYear
            rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
        >1687</foundationYear>
    </owl:NamedIndividual>

    <owl:NamedIndividual
        rdf:about="http://www.technical-sciences.org/ontology#Thermodynamics"
    >
        <rdf:type
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <hasName
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Technical Thermodynamics</hasName>
        <hasDescription
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Study of heat transfer and energy conversion</hasDescription>
        <mathematicalComplexity
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >High</mathematicalComplexity>
        <foundationYear
            rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
        >1824</foundationYear>
    </owl:NamedIndividual>

    <owl:NamedIndividual
        rdf:about="http://www.technical-sciences.org/ontology#ControlTheory"
    >
        <rdf:type
            rdf:resource="http://www.technical-sciences.org/ontology#TheoreticalDiscipline"
        />
        <hasName
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Control Theory</hasName>
        <hasDescription
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Mathematical theory of automatic control systems</hasDescription>
        <mathematicalComplexity
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Very High</mathematicalComplexity>
        <foundationYear
            rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
        >1868</foundationYear>
    </owl:NamedIndividual>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Instances of AppliedDiscipline (2+ instances)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

