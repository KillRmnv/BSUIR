            rdf:datatype="http://www.w3.org/2001/XMLSchema#integer"
        >25000000</workforceSize>
    </owl:NamedIndividual>

    <owl:NamedIndividual
        rdf:about="http://www.technical-sciences.org/ontology#MachineBuilding"
