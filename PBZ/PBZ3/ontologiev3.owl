    </owl:NamedIndividual>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Instances of IndustrySector (2+ instances)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:NamedIndividual
        rdf:about="http://www.technical-sciences.org/ontology#EnergySector"
    >
        <rdf:type
            rdf:resource="http://www.technical-sciences.org/ontology#IndustrySector"
        />
        <hasName
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Energy and Resource Sector</hasName>
        <hasDescription
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Power generation and resource extraction industries</hasDescription>
        <economicImpact
            rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
        >Global Critical Infrastructure</economicImpact>
