                                         "Clustered quantitative data rendering" ,
                                         "Wave graph plotting" ;
                oboInOwl:hasNarrowSynonym "Microarray cluster temporal graph rendering" ,
                                          "Microarray wave graph plotting" ,
                                          "Microarray wave graph rendering" ;
