             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:label "bigWig" .


###  http://edamontology.org/format_3007
:format_3007 rdf:type owl:Class ;
             rdfs:subClassOf :format_2330 ,
                             :format_2919 ,
                             :format_2920 ;
             :created_in "beta12orEarlier" ;
