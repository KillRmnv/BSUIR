   rdfs:comment "Is defined anywhere? Not in the 'unknown' version of RO. 'OBO_REL:quality_of' might be seen narrower in the sense that it only relates subjects that are a 'quality' (snap:Quality) with objects that are an 'independent_continuant' (snap:IndependentContinuant), and is broader in the sense that it relates any qualities of the object."
 ] .


###  http://edamontology.org/is_function_of
:is_function_of rdf:type owl:ObjectProperty ;
                rdfs:domain :operation_0004 ;
                oboLegacy:is_anti_symmetric "false" ;
                oboLegacy:is_reflexive "false" ;
                oboLegacy:is_symmetric "false" ;
                oboLegacy:transitive_over "OBO_REL:is_a" ;
                oboInOwl:hasDefinition "'A is_function_of B' defines for the subject A, that it is a function of the object B." ;
                oboInOwl:hasNarrowSynonym "OBO_REL:function_of" ;
                oboInOwl:hasRelatedSynonym "OBO_REL:inheres_in" ;
                oboInOwl:inSubset :properties ;
                oboInOwl:isCyclic "true"^^xsd:boolean ;
                rdfs:comment "Subject A can either be concept that is (or is in a role of) a function, or an entity outside of an ontology (or an ontology concept in a role of an entity being semantically annotated) that is (or is in a role of) a function specification. Object B can be any concept or entity. Within EDAM itself, 'is_function_of' is not used." ;
                rdfs:label "is function of" ;
                skos:broadMatch <http://www.loa.istc.cnr.it/ontologies/DOLCE-Lite.owl#inherent-in> ;
                skos:exactMatch <http://wsio.org/is_function_of> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :is_function_of ;
   owl:annotatedProperty oboInOwl:hasNarrowSynonym ;
   owl:annotatedTarget "OBO_REL:function_of" ;
   rdfs:comment "Is defined anywhere? Not in the 'unknown' version of RO. 'OBO_REL:function_of' only relates subjects that are a 'function' (snap:Function) with objects that are an 'independent_continuant' (snap:IndependentContinuant), so for example no processes. It does not define explicitly that the subject is a function of the object."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :is_function_of ;
   owl:annotatedProperty oboInOwl:hasRelatedSynonym ;
   owl:annotatedTarget "OBO_REL:inheres_in" ;
   rdfs:comment "Is defined anywhere? Not in the 'unknown' version of RO. 'OBO_REL:inheres_in' is narrower in the sense that it only relates ontological categories (concepts) that are a 'specifically_dependent_continuant' (snap:SpecificallyDependentContinuant) with ontological categories that are an 'independent_continuant' (snap:IndependentContinuant), and broader in the sense that it relates any borne subjects not just functions."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :is_function_of ;
   owl:annotatedProperty oboInOwl:isCyclic ;
   owl:annotatedTarget "true"^^xsd:boolean ;
   rdfs:comment "In very unusual cases."
 ] .


