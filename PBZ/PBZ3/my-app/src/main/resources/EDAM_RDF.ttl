           oboInOwl:hasExactSynonym "Protein interaction record" ,
                                    "Protein interaction report" ,
                                    "Protein report (interaction)" ,
                                    "Protein-protein interaction data" ;
           oboInOwl:hasNarrowSynonym "Atom interaction data" ,
                                     "Protein non-covalent interactions report" ,
                                     "Residue interaction data" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:label "Protein interaction data" .


