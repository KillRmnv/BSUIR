###  http://edamontology.org/data_0006
:data_0006 rdf:type owl:Class ;
           owl:disjointWith :format_1915 ,
                            :operation_0004 ,
                            :topic_0003 ,
                            owl:DeprecatedClass ;
           :created_in "beta12orEarlier" ;
           :notRecommendedForAnnotation "true"^^xsd:boolean ;
           oboInOwl:hasDefinition "Information, represented in an information artefact (data record) that is 'understandable' by dedicated computational tools that can use the data as input or produce it as output." ;
           oboInOwl:hasExactSynonym "Data record" ;
           oboInOwl:hasNarrowSynonym "Data set" ,
                                     "Datum" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:label "Data" ;
           skos:broadMatch oboLegacy:BFO_0000002 ,
                           oboLegacy:IAO_0000030 ,
                           <http://www.onto-med.de/ontologies/gfo.owl#Perpetuant> ;
           skos:closeMatch <http://purl.org/biotop/biotop.owl#DigitalEntity> ,
                           <http://semanticscience.org/resource/SIO_000069> ;
           skos:exactMatch <http://wsio.org/data_002> ;
           skos:narrowMatch oboLegacy:IAO_0000027 ;
           skos:relatedMatch <http://semanticscience.org/resource/SIO_000088> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :data_0006 ;
   owl:annotatedProperty oboInOwl:hasExactSynonym ;
   owl:annotatedTarget "Data record" ;
   rdfs:comment "EDAM does not distinguish a data record (a tool-understandable information artefact) from data or datum (its content, the tool-understandable encoding of an information)."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :data_0006 ;
   owl:annotatedProperty oboInOwl:hasNarrowSynonym ;
   owl:annotatedTarget "Data set" ;
   rdfs:comment "EDAM does not distinguish the multiplicity of data, such as one data item (datum) versus a collection of data (data set)."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :data_0006 ;
   owl:annotatedProperty oboInOwl:hasNarrowSynonym ;
   owl:annotatedTarget "Datum" ;
   rdfs:comment "EDAM does not distinguish the multiplicity of data, such as one data item (datum) versus a collection of data (data set)."
 ] .


