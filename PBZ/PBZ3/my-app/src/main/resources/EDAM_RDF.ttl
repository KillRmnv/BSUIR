foaf:logo rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://edamontology.org/has_format
:has_format rdf:type owl:ObjectProperty ;
            owl:inverseOf :is_format_of ;
            rdfs:domain :data_0006 ;
            rdfs:range :format_1915 ;
            oboLegacy:is_anti_symmetric "false" ;
            oboLegacy:is_reflexive "false" ;
            oboLegacy:is_symmetric "false" ;
            oboLegacy:transitive_over "OBO_REL:is_a" ;
            oboInOwl:hasDefinition "'A has_format B' defines for the subject A, that it has the object B as its data format." ;
            oboInOwl:inSubset :properties ;
            oboInOwl:isCyclic "false" ;
            rdfs:comment "Subject A can be any concept or entity outside of an ontology (or an ontology concept in a role of an entity being semantically annotated) that is (or is in a role of) 'Data', or an input, output, input or output argument of an 'Operation'. Object B can either be a concept that is a 'Format', or in unexpected cases an entity outside of an ontology that is a 'Format' or is in the role of a 'Format'. In EDAM, 'has_format' is not explicitly defined between EDAM concepts, only the inverse 'is_format_of'." ;
            rdfs:label "has format" ;
            skos:broadMatch oboLegacy:OBI_0000298 ,
                            <http://www.loa.istc.cnr.it/ontologies/DOLCE-Lite.owl#has-quality> .


###  http://edamontology.org/has_function
:has_function rdf:type owl:ObjectProperty ;
              owl:inverseOf :is_function_of ;
              rdfs:range :operation_0004 ;
              oboLegacy:is_anti_symmetric "false" ;
              oboLegacy:is_reflexive "false" ;
              oboLegacy:is_symmetric "false" ;
              oboLegacy:transitive_over "OBO_REL:is_a" ;
              oboInOwl:hasDefinition "'A has_function B' defines for the subject A, that it has the object B as its function." ;
              oboInOwl:hasRelatedSynonym "OBO_REL:bearer_of" ;
              oboInOwl:inSubset :properties ;
              oboInOwl:isCyclic "true"^^xsd:boolean ;
              rdfs:comment "Subject A can be any concept or entity outside of an ontology (or an ontology concept in a role of an entity being semantically annotated). Object B can either be a concept that is (or is in a role of) a function, or an entity outside of an ontology that is (or is in a role of) a function specification. In the scope of EDAM, 'has_function' serves only for relating annotated entities outside of EDAM with 'Operation' concepts." ;
              rdfs:label "has function" ;
              skos:broadMatch <http://www.loa.istc.cnr.it/ontologies/DOLCE-Lite.owl#has-quality> ;
              skos:closeMatch oboLegacy:OBI_0000306 ;
              skos:exactMatch <http://wsio.org/has_function> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :has_function ;
   owl:annotatedProperty oboInOwl:hasRelatedSynonym ;
   owl:annotatedTarget "OBO_REL:bearer_of" ;
   rdfs:comment "Is defined anywhere? Not in the 'unknown' version of RO. 'OBO_REL:bearer_of' is narrower in the sense that it only relates ontological categories (concepts) that are an 'independent_continuant' (snap:IndependentContinuant) with ontological categories that are a 'specifically_dependent_continuant' (snap:SpecificallyDependentContinuant), and broader in the sense that it relates with any borne objects not just functions of the subject."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :has_function ;
   owl:annotatedProperty oboInOwl:isCyclic ;
   owl:annotatedTarget "true"^^xsd:boolean ;
   rdfs:comment "In very unusual cases."
 ] .


###  http://edamontology.org/has_identifier
:has_identifier rdf:type owl:ObjectProperty ;
                owl:inverseOf :is_identifier_of ;
                rdfs:domain :data_0006 ;
                rdfs:range :data_0842 ;
                oboLegacy:is_anti_symmetric "false" ;
                oboLegacy:is_reflexive "false" ;
                oboLegacy:is_symmetric "false" ;
                oboLegacy:transitive_over "OBO_REL:is_a" ;
                oboInOwl:hasDefinition "'A has_identifier B' defines for the subject A, that it has the object B as its identifier." ;
                oboInOwl:inSubset :properties ;
                oboInOwl:isCyclic "false" ;
                rdfs:comment "Subject A can be any concept or entity outside of an ontology (or an ontology concept in a role of an entity being semantically annotated). Object B can either be a concept that is an 'Identifier', or an entity outside of an ontology that is an 'Identifier' or is in the role of an 'Identifier'. In EDAM, 'has_identifier' is not explicitly defined between EDAM concepts, only the inverse 'is_identifier_of'." ;
                rdfs:label "has identifier" .


###  http://edamontology.org/has_input
:has_input rdf:type owl:ObjectProperty ;
           owl:inverseOf :is_input_of ;
           rdfs:domain :operation_0004 ;
           rdfs:range :data_0006 ;
           oboLegacy:is_anti_symmetric "false" ;
           oboLegacy:is_reflexive "false" ;
           oboLegacy:is_symmetric "false" ;
           oboLegacy:transitive_over "OBO_REL:is_a" ;
           oboInOwl:hasDefinition "'A has_input B' defines for the subject A, that it has the object B as a necessary or actual input or input argument." ;
           oboInOwl:hasRelatedSynonym "OBO_REL:has_participant" ;
           oboInOwl:inSubset :properties ;
           oboInOwl:isCyclic "true"^^xsd:boolean ;
           rdfs:comment "Subject A can either be concept that is or has an 'Operation' function, or an entity outside of an ontology (or an ontology concept in a role of an entity being semantically annotated) that has an 'Operation' function or is an 'Operation'. Object B can be any concept or entity. In EDAM, only 'has_input' is explicitly defined between EDAM concepts ('Operation' 'has_input' 'Data'). The inverse, 'is_input_of', is not explicitly defined." ;
           rdfs:label "has input" ;
           skos:closeMatch oboLegacy:OBI_0000293 ;
           skos:exactMatch <http://wsio.org/has_input> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :has_input ;
   owl:annotatedProperty oboInOwl:hasRelatedSynonym ;
   owl:annotatedTarget "OBO_REL:has_participant" ;
   rdfs:comment "'OBO_REL:has_participant' is narrower in the sense that it only relates ontological categories (concepts) that are a 'process' (span:Process) with ontological categories that are a 'continuant' (snap:Continuant), and broader in the sense that it relates with any participating objects not just inputs or input arguments of the subject."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :has_input ;
   owl:annotatedProperty oboInOwl:isCyclic ;
