                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Diffraction data reduction" .


###  http://edamontology.org/operation_3450
:operation_3450 rdf:type owl:Class ;
                rdfs:subClassOf :operation_3443 ,
