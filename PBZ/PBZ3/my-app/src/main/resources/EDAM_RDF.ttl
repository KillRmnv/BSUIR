             oboInOwl:hasDefinition "Format used by netCDF software library for writing and reading chromatography-MS data files. Also used to store trajectory atom coordinates information, such as the ones obtained by Molecular Dynamics simulations." ;
             oboInOwl:hasExactSynonym "ANDI-MS" ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:comment "Network Common Data Form (NetCDF) library is supported by AMBER MD package from version 9." ;
