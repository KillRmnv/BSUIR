###  http://edamontology.org/topic_4046
:topic_4046 rdf:type owl:Class ;
            rdfs:subClassOf :topic_0605 ;
            :created_in "1.26" ;
            oboInOwl:created_by "Matúš Kalaš" ;
            oboInOwl:creation_date "2023-02-09T11:13:21.41427Z" ;
            oboInOwl:hasBroadSynonym "Version tracking" ;
            oboInOwl:hasDefinition "Version control is a technology for consistent management, storing, and sharing of evolving versions of digital artefacts, such as computer programs, scripts, documents, data, or media files." ;
            oboInOwl:hasNarrowSynonym "Source control" ;
            oboInOwl:hasRelatedSynonym "Source control system" ,
                                       "Version control system" ,
                                       "Versioning system" ;
            oboInOwl:inSubset :bio ,
                              :topics ;
            oboInOwl:savedBy "Matúš Kalaš" ,
                             "bianchini" ;
            rdfs:comment "Distributed version control is particularly useful for open, collaborative development of software and other creative work, enabling global communities to work cohesively." ,
                         "Version control originates from software engineering, with the purpose of managing source code. However, version control is applicable to other digital artefacts, especially any kind of text-based files. With certain limitations, version control can also be applied to binary files." ;
            rdfs:label "Version control" ;
            rdfs:seeAlso <https://en.wikipedia.org/wiki/Version_control> ;
            skos:exactMatch <https://www.wikidata.org/wiki/Q189439> .


###  http://edamontology.org/topic_4047
:topic_4047 rdf:type owl:Class ;
            rdfs:subClassOf :topic_0605 ;
            :created_in "1.26" ;
            :related_term "Code stewardship" ,
                          "Service curation" ,
                          "Service registry" ,
                          "Software archive" ,
                          "Software curation" ,
                          "Software registry" ,
                          "Software stewardship" ,
                          "Tool curation" ,
                          "Tool registry" ,
                          "Workflow curation" ,
                          "Workflow registry" ;
            oboInOwl:created_by "Matúš Kalaš" ;
            oboInOwl:creation_date "2023-02-25T02:40:36.851802Z" ;
            oboInOwl:hasDefinition "Software management comprises the practices and principles of taking care of software and software-based or software-like services, other than programming and maintenance. This includes for example taking care of the associated information and documentation, and the processes of contribution, validation, release/publication, or deployment." ;
            oboInOwl:hasRelatedSynonym "Service management" ;
            oboInOwl:inSubset :bio ,
                              :topics ;
            oboInOwl:savedBy "Matúš Kalaš" ,
                             "bianchini" ;
            rdfs:comment "The purpose of software management is keeping software or service consistent, easy to use, to update, and to expand. Good software management improves the visibility, impact, and lifetime of software and software-based or software-like services." ;
            rdfs:label "Software management" ;
            skos:relatedMatch <https://www.wikidata.org/wiki/Q947779> .


