             :repository <https://github.com/gtrack/gtrack> ;
             oboInOwl:hasDbXref <https://hyperbrowser.uio.no/gsuite/static/hyperbrowser/gsuite/GSuite_specification.html> ,
                                <https://hyperbrowser.uio.no/gsuite/static/hyperbrowser/gsuite/GSuite_specification.txt> ;
             oboInOwl:hasDefinition "GSuite is a tabular format for collections of genome or sequence feature tracks, suitable for integrative multi-track analysis. GSuite contains links to genome/sequence tracks, with additional metadata." ;
             oboInOwl:hasExactSynonym "BioXSD/GTrack GSuite" ,
                                      "BioXSD|GTrack GSuite" ,
                                      "GSuite (GTrack ecosystem of formats)" ,
                                      "GSuite format" ,
