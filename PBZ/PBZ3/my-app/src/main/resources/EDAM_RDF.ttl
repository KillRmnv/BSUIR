###  http://edamontology.org/format_4058
:format_4058 rdf:type owl:Class ;
             rdfs:subClassOf :format_2330 ,
                             :format_3245 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :has_topic ;
                               owl:someValuesFrom :topic_3172
                             ] ;
             :citation <https://doi.org/10.1021/acs.analchem.8b04310> ;
             :created_in "1.26" ;
             :documentation <https://hupo-psi.github.io/mzTab/2_0-metabolomics-release/mzTab_format_specification_2_0-M_release.html> ;
             :example <https://github.com/HUPO-PSI/mzTab/wiki/Examples#mztab-20-example-files> ;
             :file_extension "mztab" ;
             :ontology_used oboLegacy:ms.owl ,
                            "More ontologies and controlled vocabularies can be used in certain cases: Unit Ontology, ChEBI, OBI, NCBITaxon, BRENDA tissue, Cell Type ontology, DOID, XLMOD, PRIDE ontology, MSIO, NCIT." ;
             :organisation <https://www.psidev.info> ;
             :repository <https://github.com/HUPO-PSI/mzTab> ;
             oboInOwl:created_by "Claudia Blankenburg" ;
             oboInOwl:creation_date "2021-12-15" ;
             oboInOwl:hasDefinition "mzTab-M is a light-weight, tab-delimited format for mass spectrometry-based chemical profiling data, including metabolomics." ;
             oboInOwl:hasExactSynonym "mzTab 2" ;
             oboInOwl:hasNarrowSynonym "mzTab 2.0" ,
                                       "mzTab 2.1" ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             oboInOwl:savedBy "2025-11 Matúš Kalaš" ;
             rdfs:comment "The reference implementation of mzTab-M in Java is https://github.com/lifs-tools/jmzTab-m." ,
                          "mzTab-M is alternatively named mzTab 2.0, but in 2025 there is a draft version 2.1 of mzTab-M." ,
                          "mzTab-M is not compatible with mzTab (also named mzTab 1.0, for proteomics, http://edamontology.org/format_3681). Note: the repository, website, and file extension are the same for both formats." ;
             rdfs:label "mzTab-M" ;
             skos:exactMatch <https://doi.org/10.25504/FAIRsharing.207caf> .


###  http://edamontology.org/format_4059
:format_4059 rdf:type owl:Class ;
