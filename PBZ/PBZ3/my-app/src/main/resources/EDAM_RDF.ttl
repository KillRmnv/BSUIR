                rdfs:comment "Includes secondary structure assignment from circular dichroism (CD) spectroscopic data, and from protein coordinate data." ;
                rdfs:label "Protein secondary structure assignment" .


###  http://edamontology.org/operation_0320
:operation_0320 rdf:type owl:Class ;
                rdfs:subClassOf :operation_2406 ,
                                :operation_2423 ,
                                [ rdf:type owl:Restriction ;
