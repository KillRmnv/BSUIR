                oboInOwl:hasDefinition "The process of assembling many short DNA sequences together such that they represent the original chromosomes from which the DNA originated." ;
                oboInOwl:hasExactSynonym "Genomic assembly" ,
                                         "Sequence assembly (genome assembly)" ;
                oboInOwl:hasNarrowSynonym "Breakend assembly" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Genome assembly" ;
                rdfs:seeAlso <https://en.wikipedia.org/wiki/Sequence_assembly#Genome_assemblers> .


