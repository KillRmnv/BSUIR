                                      "GTrack|GSuite|BTrack GSuite" ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:comment "'GSuite' belongs to the 'BioXSD|GTrack' ecosystem of generic formats, and particular to its subset, the 'GTrack ecosystem' (GTrack, GSuite, BTrack). 'GSuite' is the tabular format for an annotated collection of individual GTrack files." ;
             rdfs:label "GSuite" ;
             rdfs:seeAlso <https://hyperbrowser.uio.no/gsuite> .


###  http://edamontology.org/format_3776
:format_3776 rdf:type owl:Class ;
