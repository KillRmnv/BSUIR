             oboInOwl:hasDbXref <http://genome.ucsc.edu/FAQ/FAQformat#format1.5> ;
             oboInOwl:hasDefinition "bigBed format for large sequence annotation tracks, similar to textual BED format." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:label "bigBed" .


