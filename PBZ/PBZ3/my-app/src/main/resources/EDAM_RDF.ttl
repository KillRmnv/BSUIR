###  http://edamontology.org/operation_2949
:operation_2949 rdf:type owl:Class ;
                rdfs:subClassOf :operation_1777 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_output ;
                                  owl:someValuesFrom :data_0906
                                ] ,
                                [ rdf:type owl:Restriction ;
