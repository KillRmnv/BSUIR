###  http://edamontology.org/format_3590
:format_3590 rdf:type owl:Class ;
             rdfs:subClassOf :format_2333 ,
                             :format_3867 ;
             :created_in "1.11" ;
             :documentation <https://www.hdfgroup.org/HDF5/doc/H5.format.html> ;
             oboInOwl:hasDbXref <https://www.hdfgroup.org/HDF5/doc/H5.format.html> ;
             oboInOwl:hasDefinition "HDF5 is a data model, library, and file format for storing and managing data, based on Hierarchical Data Format (HDF)." ;
             oboInOwl:hasExactSynonym "h5" ;
             oboInOwl:inSubset :bio ,
                               :formats ;
