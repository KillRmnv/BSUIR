###  http://edamontology.org/topic_3071
:topic_3071 rdf:type owl:Class ;
            rdfs:subClassOf :topic_0003 ;
            :created_in "beta13" ;
            :isdebtag "true"^^xsd:boolean ;
            :related_term "Data life cycle" ,
                          "Data lifecycle" ;
            oboInOwl:hasDbXref "VT 1.3.1 Data management" ;
            oboInOwl:hasDefinition "Data management comprises the practices and principles of taking care of data, other than analysing them. This includes for example taking care of the associated metadata, data formats, storage, preservation/archiving, access, and legal aspects related to using and sharing data." ;
            oboInOwl:hasNarrowSynonym "Metadata management" ,
                                      "Research data management (RDM)" ;
            oboInOwl:inSubset :bio ,
                              :events ,
                              :topics ;
            oboInOwl:savedBy "Matúš Kalaš" ,
                             "bianchini" ,
                             "erin.calhoun" ;
            rdfs:comment "The purpose of data management is keeping data consistent, easy to access and use, while ensuring a required level of data protection. Good data management improves the visibility, impact, and lifetime of data." ;
            rdfs:label "Data management" ;
            rdfs:seeAlso <https://en.wikipedia.org/wiki/Data_management> ,
                         <https://en.wikipedia.org/wiki/Metadata_management> ;
            skos:editorialNote "Revise more eventual concepts from https://en.wikipedia.org/wiki/Data_management etc." ;
