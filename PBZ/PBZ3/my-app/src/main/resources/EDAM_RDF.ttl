             oboInOwl:hasDbXref <http://genome.ucsc.edu/FAQ/FAQformat#format8> ;
             oboInOwl:hasDefinition ".nib (nibble) binary format of a nucleotide sequence using 4 bits per nucleotide (including unknown) and its lower-case 'masking'." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:label ".nib" .


###  http://edamontology.org/format_3011
