                oboInOwl:hasExactSynonym "Taxonomy assignment" ;
                oboInOwl:hasNarrowSynonym "Taxonomic profiling" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Taxonomic classification" .


