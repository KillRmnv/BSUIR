###  http://edamontology.org/operation_3453
:operation_3453 rdf:type owl:Class ;
                rdfs:subClassOf :operation_3445 ;
                :created_in "1.7" ;
                oboInOwl:hasDefinition "The evaluation of diffraction intensities and integration of diffraction maxima from a diffraction experiment." ;
                oboInOwl:hasNarrowSynonym "Diffraction profile fitting" ,
                                          "Diffraction summation integration" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Diffraction data integration" .


###  http://edamontology.org/operation_3454
:operation_3454 rdf:type owl:Class ;
                rdfs:subClassOf :operation_3445 ;
                :created_in "1.7" ;
                oboInOwl:hasDefinition "Phase a macromolecular crystal structure, for example by using molecular replacement or experimental phasing methods." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Phasing" .


###  http://edamontology.org/operation_3455
:operation_3455 rdf:type owl:Class ;
                rdfs:subClassOf :operation_0322 ;
                :created_in "1.7" ;
                oboInOwl:hasDefinition "A technique used to construct an atomic model of an unknown structure from diffraction data, based upon an atomic model of a known structure, either a related protein or the same protein from a different crystal form." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "The technique solves the phase problem, i.e. retrieve information concern phases of the structure." ;
                rdfs:label "Molecular replacement" .


###  http://edamontology.org/operation_3456
:operation_3456 rdf:type owl:Class ;
                rdfs:subClassOf :operation_0322 ;
                :created_in "1.7" ;
                oboInOwl:hasDefinition "A method used to refine a structure by moving the whole molecule or parts of it as a rigid unit, rather than moving individual atoms." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "Rigid body refinement usually follows molecular replacement in the assignment of a structure from diffraction data." ;
                rdfs:label "Rigid body refinement" .


###  http://edamontology.org/operation_3457
:operation_3457 rdf:type owl:Class ;
                rdfs:subClassOf :operation_2480 ,
                                :operation_3443 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_topic ;
                                  owl:someValuesFrom :topic_1317
                                ] ;
                :created_in "1.7" ;
                oboInOwl:hasDefinition "An image processing technique that combines and analyze multiple images of a particulate sample, in order to produce an image with clearer features that are more easily interpreted." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "Single particle analysis is used to improve the information that can be obtained by relatively low resolution techniques, , e.g. an image of a protein or virus from transmission electron microscopy (TEM)." ;
                rdfs:label "Single particle analysis" ;
                rdfs:seeAlso <https://en.wikipedia.org/wiki/Single_particle_analysis> .


###  http://edamontology.org/operation_3458
:operation_3458 rdf:type owl:Class ;
                rdfs:subClassOf :operation_2990 ,
                                :operation_3457 ;
                :created_in "1.7" ;
                :is_refactor_candidate "true"^^xsd:boolean ;
                :refactor_comment "This is two related concepts." ;
                oboInOwl:hasDefinition "Compare (align and classify) multiple particle images from a micrograph in order to produce a representative image of the particle." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "A micrograph can include particles in multiple different orientations and/or conformations. Particles are compared and organised into sets based on their similarity. Typically iterations of classification and alignment and are performed to optimise the final 3D EM map." ;
                rdfs:label "Single particle alignment and classification" .


###  http://edamontology.org/operation_3459
:operation_3459 rdf:type owl:Class ;
                rdfs:subClassOf :operation_0291 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_topic ;
                                  owl:someValuesFrom :topic_1775
                                ] ;
                :created_in "1.7" ;
                oboInOwl:hasDefinition "Clustering of molecular sequences on the basis of their function, typically using information from an ontology of gene function, or some other measure of functional phenotype." ;
                oboInOwl:hasExactSynonym "Functional sequence clustering" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Functional clustering" .


###  http://edamontology.org/operation_3460
