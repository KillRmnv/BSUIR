@prefix : <http://edamontology.org/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oboInOwl: <http://www.geneontology.org/formats/oboInOwl#> .
@prefix oboLegacy: <http://purl.obolibrary.org/obo/> .
@base <http://edamontology.org/> .

<http://edamontology.org> rdf:type owl:Ontology ;
                           :citation <https://doi.org/10.7490/f1000research.1118900.1> ;
                           :next_id "4061" ;
                           :repository <https://github.com/edamontology/edamontology> ;
                           oboLegacy:date "12.11.2025 16:20 UTC" ;
                           oboLegacy:idspace "EDAM http://edamontology.org/ \"EDAM relations, concept properties, and subsets\"" ,
                                             "EDAM_data http://edamontology.org/data_ \"EDAM types of data\"" ,
                                             "EDAM_format http://edamontology.org/format_ \"EDAM data formats\"" ,
                                             "EDAM_operation http://edamontology.org/operation_ \"EDAM operations\"" ,
                                             "EDAM_topic http://edamontology.org/topic_ \"EDAM topics\"" ;
                           oboLegacy:remark "EDAM is a community project and its development can be followed and contributed to at https://github.com/edamontology/edamontology." ,
                                            "EDAM is particularly suitable for semantic annotations and categorisation of diverse resources related to data analysis and management: e.g. tools, workflows, learning materials, or standards. EDAM is also useful in data management itself, for recording provenance metadata of processed data." ;
                           dc:contributor "Claudia Blankenburg" ,
                                          "https://github.com/edamontology/edamontology/graphs/contributors and many more!" ;
                           dc:creator "Claire Rioualen" ,
                                      "Federico Bianchini" ,
                                      "Hervé Ménager" ,
                                      "Jon Ison" ,
                                      "Matúš Kalaš" ;
                           dc:description "EDAM is a domain ontology of data analysis and data management in bio- and other sciences, and science-based applications. It comprises concepts related to analysis, modelling, optimisation, and data life cycle. Targetting usability by diverse users, the structure of EDAM is relatively simple, divided into 4 main sections: Topic, Operation, Data (incl. Identifier), and Format." ;
                           dc:format "application/rdf+xml" ;
                           dc:title "EDAM - The ontology of data analysis and management" ;
                           dcterms:format <http://www.iana.org/assignments/media-types/application/rdf+xml> ;
                           dcterms:license <https://creativecommons.org/licenses/by-sa/4.0> ;
                           doap:Version "dev(1.26)" ;
                           oboInOwl:hasSubset :bio ,
                                              :data ,
                                              :events ,
                                              :formats ,
                                              :identifiers ,
                                              :obsolete ,
                                              :operations ,
                                              :properties ,
                                              :topics ;
                           rdfs:isDefinedBy :EDAM.owl ;
                           owl:priorVersion <http://edamontology.org/1.25> ;
                           foaf:logo <https://raw.githubusercontent.com/edamontology/edamontology/main/EDAM-logo-square.svg> ;
                           foaf:page :page .

#################################################################
#    Annotation properties
#################################################################

###  http://edamontology.org/bio
:bio rdf:type owl:AnnotationProperty ;
     rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/citation
:citation rdf:type owl:AnnotationProperty ;
          :created_in "1.13" ;
          oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
          oboInOwl:hasBroadSynonym "Publication reference" ;
          oboInOwl:hasDefinition "'Citation' concept property ('citation' metadata tag) contains a dereferenceable URI, preferably including a DOI, pointing to a citeable publication of the given data format." ;
          oboInOwl:hasRelatedSynonym "Publication" ;
          oboInOwl:inSubset :properties ;
          rdfs:label "Citation" .


###  http://edamontology.org/comment_handle
:comment_handle rdf:type owl:AnnotationProperty .


###  http://edamontology.org/created_by
:created_by rdf:type owl:AnnotationProperty .


###  http://edamontology.org/created_in
:created_in rdf:type owl:AnnotationProperty ;
            oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
            oboInOwl:hasDefinition "Version in which a concept was created." ;
            oboInOwl:inSubset :properties ;
            rdfs:label "Created in" .


###  http://edamontology.org/data
:data rdf:type owl:AnnotationProperty ;
      rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/deprecation_comment
:deprecation_comment rdf:type owl:AnnotationProperty ;
                     oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                     oboInOwl:hasDefinition "A comment explaining why the comment should be or was deprecated, including name of person commenting (jison, mkalas etc.)." ;
                     oboInOwl:inSubset :properties ;
                     rdfs:label "deprecation_comment" .


###  http://edamontology.org/documentation
:documentation rdf:type owl:AnnotationProperty ;
               oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
               oboInOwl:hasDefinition "'Documentation' trailing modifier (qualifier, 'documentation') of 'xref' links of 'Format' concepts. When 'true', the link is pointing to a page with explanation, description, documentation, or specification of the given data format." ;
               oboInOwl:hasRelatedSynonym "Specification" ;
               oboInOwl:inSubset :properties ;
               rdfs:label "Documentation" .


###  http://edamontology.org/events
:events rdf:type owl:AnnotationProperty ;
        rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/example
:example rdf:type owl:AnnotationProperty ;
         oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
         oboInOwl:hasDefinition "'Example' concept property ('example' metadata tag) lists examples of valid values of types of identifiers (accessions). Applicable to some other types of data, too." ;
         oboInOwl:inSubset :properties ;
         rdfs:comment "Separated by bar ('|'). For more complex data and data formats, it can be a link to a website with examples, instead." ;
         rdfs:label "Example" .


###  http://edamontology.org/file_extension
:file_extension rdf:type owl:AnnotationProperty ;
                oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                oboInOwl:hasDefinition "'File extension' concept property ('file_extension' metadata tag) lists examples of usual file extensions of formats." ;
                oboInOwl:inSubset :properties ;
                rdfs:comment "N.B.: File extensions that are not correspondigly defined at http://filext.com are recorded in EDAM only if not in conflict with http://filext.com, and/or unique and usual within life-science computing." ,
                             "Separated by bar ('|'), without a dot ('.') prefix, preferably not all capital characters." ;
                rdfs:label "File extension" .


###  http://edamontology.org/formats
:formats rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/hasHumanReadableId
:hasHumanReadableId rdf:type owl:AnnotationProperty .


###  http://edamontology.org/identifiers
:identifiers rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/information_standard
:information_standard rdf:type owl:AnnotationProperty ;
                      oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                      oboInOwl:hasDefinition "'Information standard' trailing modifier (qualifier, 'information_standard') of 'xref' links of 'Format' concepts. When 'true', the link is pointing to an information standard supported by the given data format." ;
                      oboInOwl:hasNarrowSynonym "Minimum information checklist" ,
                                                "Minimum information standard" ;
                      oboInOwl:inSubset :properties ;
                      rdfs:comment "\"Supported by the given data format\" here means, that the given format enables representation of data that satisfies the information standard." ;
                      rdfs:label "Information standard" .


###  http://edamontology.org/is_deprecation_candidate
:is_deprecation_candidate rdf:type owl:AnnotationProperty ;
                          oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                          oboInOwl:hasDefinition "When 'true', the concept has been proposed to be deprecated." ;
                          oboInOwl:inSubset :properties ;
                          rdfs:label "deprecation_candidate" .


###  http://edamontology.org/is_refactor_candidate
:is_refactor_candidate rdf:type owl:AnnotationProperty ;
                       oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                       oboInOwl:hasDefinition "When 'true', the concept has been proposed to be refactored." ;
                       oboInOwl:inSubset :properties ;
                       rdfs:label "refactor_candidate" .


###  http://edamontology.org/isdebtag
:isdebtag rdf:type owl:AnnotationProperty ;
          oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
          oboInOwl:hasDefinition "When 'true', the concept has been proposed or is supported within Debian as a tag." ;
          oboInOwl:inSubset :properties ;
          rdfs:label "isdebtag" .


###  http://edamontology.org/media_type
:media_type rdf:type owl:AnnotationProperty ;
            oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
            oboInOwl:hasDefinition "'Media type' trailing modifier (qualifier, 'media_type') of 'xref' links of 'Format' concepts. When 'true', the link is pointing to a page specifying a media type of the given data format." ;
            oboInOwl:hasNarrowSynonym "MIME type" ;
            oboInOwl:inSubset :properties ;
            rdfs:label "Media type" .


###  http://edamontology.org/next_id
:next_id rdf:type owl:AnnotationProperty .


###  http://edamontology.org/notRecommendedForAnnotation
:notRecommendedForAnnotation rdf:type owl:AnnotationProperty ;
                             oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                             oboInOwl:hasDefinition "Whether terms associated with this concept are recommended for use in annotation." ;
                             oboInOwl:inSubset :properties ;
                             rdfs:label "notRecommendedForAnnotation" .


###  http://edamontology.org/obsolete
:obsolete rdf:type owl:AnnotationProperty ;
          rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/obsolete_since
:obsolete_since rdf:type owl:AnnotationProperty ;
                oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                oboInOwl:hasDefinition "Version in which a concept was made obsolete." ;
                oboInOwl:inSubset :properties ;
                rdfs:label "Obsolete since" .


###  http://edamontology.org/oldParent
:oldParent rdf:type owl:AnnotationProperty ;
           oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
           oboInOwl:hasDefinition "EDAM concept URI of the erstwhile \"parent\" of a now deprecated concept." ;
           oboInOwl:inSubset :properties ;
           rdfs:label "Old parent" .


###  http://edamontology.org/oldRelated
:oldRelated rdf:type owl:AnnotationProperty ;
            oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
            oboInOwl:hasDefinition "EDAM concept URI of an erstwhile related concept (by has_input, has_output, has_topic, is_format_of, etc.) of a now deprecated concept." ;
            oboInOwl:inSubset :properties ;
            rdfs:label "Old related" .


###  http://edamontology.org/ontology_used
:ontology_used rdf:type owl:AnnotationProperty ;
               oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
               oboInOwl:hasDefinition "'Ontology used' concept property ('ontology_used' metadata tag) of format concepts links to a domain ontology that is used inside the given data format, or contains a note about ontology use within the format." ;
               oboInOwl:inSubset :properties ;
               rdfs:label "Ontology used" .


###  http://edamontology.org/operations
:operations rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://edamontology.org/organisation
:organisation rdf:type owl:AnnotationProperty ;
              oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
              oboInOwl:hasDefinition "'Organisation' trailing modifier (qualifier, 'organisation') of 'xref' links of 'Format' concepts. When 'true', the link is pointing to an organisation that developed, standardised, and maintains the given data format." ;
              oboInOwl:hasExactSynonym "Organization" ;
              oboInOwl:inSubset :properties ;
              rdfs:label "Organisation" .


###  http://edamontology.org/refactor_comment
:refactor_comment rdf:type owl:AnnotationProperty ;
                  oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                  oboInOwl:hasDefinition "A comment explaining the proposed refactoring, including name of person commenting (jison, mkalas etc.)." ;
                  oboInOwl:inSubset :properties ;
                  rdfs:label "refactor_comment" .


###  http://edamontology.org/regex
:regex rdf:type owl:AnnotationProperty ;
       oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
       oboInOwl:hasDefinition "'Regular expression' concept property ('regex' metadata tag) specifies the allowed values of types of identifiers (accessions). Applicable to some other types of data, too." ;
       oboInOwl:inSubset :properties ;
       rdfs:label "Regular expression" .


###  http://edamontology.org/related_term
:related_term rdf:type owl:AnnotationProperty ;
              oboInOwl:hasDefinition "'Related term' concept property ('related_term'; supposedly a synonym modifier in OBO format) states a related term - not necessarily closely semantically related - that users (also non-specialists) may use when searching." ;
              oboInOwl:inSubset :properties ;
              rdfs:label "Related term" ;
              rdfs:subPropertyOf oboInOwl:hasRelatedSynonym .


###  http://edamontology.org/repository
:repository rdf:type owl:AnnotationProperty ;
            oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
            oboInOwl:hasDefinition "'Repository' trailing modifier (qualifier, 'repository') of 'xref' links of 'Format' concepts. When 'true', the link is pointing to the public source-code repository where the given data format is developed or maintained." ;
            oboInOwl:hasExactSynonym "Public repository" ,
                                     "Source-code repository" ;
            oboInOwl:inSubset :properties ;
            rdfs:label "Repository" .


###  http://edamontology.org/thematic_editor
:thematic_editor rdf:type owl:AnnotationProperty ;
                 oboLegacy:is_metadata_tag "true"^^xsd:boolean ;
                 oboInOwl:hasDefinition "Name of thematic editor (http://biotools.readthedocs.io/en/latest/governance.html#registry-editors) responsible for this concept and its children." ;
                 oboInOwl:inSubset :properties ;
                 rdfs:label "thematic_editor" .


###  http://edamontology.org/topics
:topics rdf:type owl:AnnotationProperty ;
        rdfs:subPropertyOf oboInOwl:SubsetProperty .


###  http://purl.obolibrary.org/obo/date
oboLegacy:date rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/idspace
oboLegacy:idspace rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/is_anti_symmetric
oboLegacy:is_anti_symmetric rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/is_metadata_tag
oboLegacy:is_metadata_tag rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/is_reflexive
oboLegacy:is_reflexive rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/is_symmetric
oboLegacy:is_symmetric rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/namespace
oboLegacy:namespace rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/remark
oboLegacy:remark rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/transitive_over
oboLegacy:transitive_over rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/contributor
dc:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/format
dc:format rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/format
dcterms:format rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://usefulinc.com/ns/doap#Version
doap:Version rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#SubsetProperty
oboInOwl:SubsetProperty rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#comment
oboInOwl:comment rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#consider
oboInOwl:consider rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#created_by
oboInOwl:created_by rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#creation_date
oboInOwl:creation_date rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasAlternativeId
oboInOwl:hasAlternativeId rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym
oboInOwl:hasBroadSynonym rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasDbXref
oboInOwl:hasDbXref rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasDefinition
oboInOwl:hasDefinition rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasExactSynonym
oboInOwl:hasExactSynonym rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasHumanReadableId
oboInOwl:hasHumanReadableId rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym
oboInOwl:hasNarrowSynonym rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym
oboInOwl:hasRelatedSynonym rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasSubset
oboInOwl:hasSubset rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#inSubset
oboInOwl:inSubset rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#isCyclic
oboInOwl:isCyclic rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#replacedBy
oboInOwl:replacedBy rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#savedBy
oboInOwl:savedBy rdf:type owl:AnnotationProperty .


