:operation_3963 rdf:type owl:Class ;
                rdfs:subClassOf :operation_3961 ;
                :created_in "1.25" ;
                oboInOwl:hasDefinition "Identify duplication events causing the number of repeats in the genome to vary between individuals." ;
                oboInOwl:inSubset :bio ,
