             oboInOwl:hasDefinition "PRIDE XML is an XML format for mass spectra, peptide and protein identifications, and metadata about a corresponding measurement, sample, experiment." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:label "PRIDE XML" .


###  http://edamontology.org/format_3685
:format_3685 rdf:type owl:Class ;
             rdfs:subClassOf :format_2332 ,
                             :format_3167 ;
             :citation <http://doi.org/10.1007/978-3-540-88562-7_15> ,
                       <http://doi.org/10.1186/1752-0509-5-198> ;
             :created_in "1.13" ;
             :documentation <http://sed-ml.org> ;
             oboInOwl:hasDbXref <http://sed-ml.org> ;
             oboInOwl:hasDefinition "Simulation Experiment Description Markup Language (SED-ML) is an XML format for encoding simulation setups, according to the MIASE (Minimum Information About a Simulation Experiment) requirements." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:label "SED-ML" .


###  http://edamontology.org/format_3686
:format_3686 rdf:type owl:Class ;
             rdfs:subClassOf :format_2013 ,
                             :format_2333 ,
                             :format_3167 ;
             :citation <http://doi.org/10.1186/s12859-014-0369-z> ;
             :created_in "1.13" ;
             :documentation <http://co.mbine.org/documents/archive> ;
             oboInOwl:hasDbXref <http://co.mbine.org/documents/archive> ;
             oboInOwl:hasDefinition "Open Modeling EXchange format (OMEX) is a ZIPped format for encapsulating all information necessary for a modeling and simulation project in systems biology." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:comment "An OMEX file is a ZIP container that includes a manifest file, listing the content of the archive, an optional metadata file adding information about the archive and its content, and the files describing the model. OMEX is one of the standardised formats within COMBINE (Computational Modeling in Biology Network)." ;
             rdfs:label "COMBINE OMEX" .


###  http://edamontology.org/format_3687
:format_3687 rdf:type owl:Class ;
             rdfs:subClassOf :format_2058 ,
                             :format_2330 ,
                             :format_3167 ;
             :created_in "1.13" ;
             :documentation <http://www.isa-tools.org/format/specification> ;
             oboInOwl:hasDbXref <http://www.isa-tools.org/format/specification> ;
             oboInOwl:hasDefinition "The Investigation / Study / Assay (ISA) tab-delimited (TAB) format incorporates metadata from experiments employing a combination of technologies." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:comment "ISA-TAB is based on MAGE-TAB. Other than tabular, the ISA model can also be represented in RDF, and in JSON (compliable with a set of defined JSON Schemata)." ;
             rdfs:label "ISA-TAB" .


