                oboInOwl:hasExactSynonym "Codon usage table construction" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Codon usage table generation" .


###  http://edamontology.org/operation_0285
:operation_0285 rdf:type owl:Class ;
                rdfs:subClassOf :operation_0286 ,
