###  http://edamontology.org/data_1276
:data_1276 rdf:type owl:Class ;
           rdfs:subClassOf :data_1255 ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDefinition "An informative report on intrinsic positional features of a nucleotide sequence, formatted to be machine-readable." ;
           oboInOwl:hasExactSynonym "Feature table (nucleic acid)" ,
                                    "Nucleic acid feature table" ;
           oboInOwl:hasNarrowSynonym "Genome features" ,
                                     "Genomic features" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "This includes nucleotide sequence feature annotation in any known sequence feature table format and any other report of nucleic acid features." ;
           rdfs:label "Nucleic acid features" .


###  http://edamontology.org/data_1277
:data_1277 rdf:type owl:Class ;
           rdfs:subClassOf :data_0896 ,
                           :data_1255 ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDefinition "An informative report on intrinsic positional features of a protein sequence." ;
           oboInOwl:hasExactSynonym "Feature table (protein)" ,
                                    "Protein feature table" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "This includes protein sequence feature annotation in any known sequence feature table format and any other report of protein features." ;
           rdfs:label "Protein features" .


###  http://edamontology.org/data_1278
:data_1278 rdf:type owl:Class ;
           rdfs:subClassOf :data_1274 ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDbXref "Moby:GeneticMap" ;
           oboInOwl:hasDefinition "A map showing the relative positions of genetic markers in a nucleic acid sequence, based on estimation of non-physical distance such as recombination frequencies." ;
           oboInOwl:hasExactSynonym "Linkage map" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "A genetic (linkage) map indicates the proximity of two genes on a chromosome, whether two genes are linked and the frequency they are transmitted together to an offspring. They are limited to genetic markers of traits observable only in whole organisms." ;
           rdfs:label "Genetic map" .


###  http://edamontology.org/data_1279
:data_1279 rdf:type owl:Class ;
           rdfs:subClassOf :data_1280 ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDefinition "A map of genetic markers in a contiguous, assembled genomic sequence, with the sizes and separation of markers measured in base pairs." ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "A sequence map typically includes annotation on significant subsequences such as contigs, haplotypes and genes. The contigs shown will (typically) be a set of small overlapping clones representing a complete chromosomal segment." ;
           rdfs:label "Sequence map" .


###  http://edamontology.org/data_1280
:data_1280 rdf:type owl:Class ;
           rdfs:subClassOf :data_1274 ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDefinition "A map of DNA (linear or circular) annotated with physical features or landmarks such as restriction sites, cloned DNA fragments, genes or genetic markers, along with the physical distances between them." ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "Distance in a physical map is measured in base pairs. A physical map might be ordered relative to a reference map (typically a genetic map) in the process of genome sequencing." ;
           rdfs:label "Physical map" .


###  http://edamontology.org/data_1281
:data_1281 rdf:type owl:Class ;
           rdfs:subClassOf owl:DeprecatedClass ;
           :created_in "beta12orEarlier" ;
           :obsolete_since "beta12orEarlier" ;
           :oldParent owl:Thing ;
           oboInOwl:hasDefinition "Image of a sequence with matches to signatures, motifs or profiles." ;
           oboInOwl:inSubset :obsolete ;
           oboInOwl:replacedBy :data_2969 ;
           rdfs:label "Sequence signature map" ;
           owl:deprecated "true"^^xsd:boolean .


###  http://edamontology.org/data_1283
:data_1283 rdf:type owl:Class ;
           rdfs:subClassOf :data_1280 ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDefinition "A map showing banding patterns derived from direct observation of a stained chromosome." ;
           oboInOwl:hasExactSynonym "Chromosome map" ,
                                    "Cytogenic map" ,
                                    "Cytologic map" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "This is the lowest-resolution physical map and can provide only rough estimates of physical (base pair) distances. Like a genetic map, they are limited to genetic markers of traits observable only in whole organisms." ;
           rdfs:label "Cytogenetic map" .


