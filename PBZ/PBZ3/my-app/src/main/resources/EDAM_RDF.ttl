                rdfs:label "Format detection" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :operation_3357 ;
   owl:annotatedProperty :comment_handle ;
   owl:annotatedTarget :comment_handle ;
   rdfs:comment "The has_input \"Data\" (data_0006) may cause visualisation or other problems although ontologically correct. But on the other hand it may be useful to distinguish from nullary operations without inputs."
 ] .


