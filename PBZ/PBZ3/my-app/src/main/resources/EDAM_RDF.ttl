###  http://edamontology.org/operation_3964
:operation_3964 rdf:type owl:Class ;
                rdfs:subClassOf :operation_3961 ;
                :created_in "1.25" ;
                oboInOwl:hasDefinition "Identify copy number variations which are complex, e.g. multi-allelic variations that have many structural alleles and have rearranged multiple times in the ancestral genomes." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:label "Complex CNV detection" .


###  http://edamontology.org/operation_3965
:operation_3965 rdf:type owl:Class ;
