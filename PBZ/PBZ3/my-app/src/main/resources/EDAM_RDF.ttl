                                  owl:someValuesFrom :topic_0114
                                ] ;
                :created_in "beta12orEarlier" ;
                oboInOwl:hasDefinition "Detect, predict and identify genes or components of genes in DNA sequences, including promoters, coding regions, splice sites, etc." ;
                oboInOwl:hasExactSynonym "Gene calling" ,
                                         "Gene finding" ;
                oboInOwl:hasNarrowSynonym "Whole gene prediction" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "Includes methods that predict whole gene structure using a combination of multiple methods to achieve better predictions." ,
                             "Methods for gene prediction might be ab initio, based on phylogenetic comparisons, use motifs, sequence features, support vector machine, alignment etc." ;
                rdfs:label "Gene prediction" ;
                rdfs:seeAlso <https://en.wikipedia.org/wiki/Gene_prediction> .


