###  http://edamontology.org/format_3859
:format_3859 rdf:type owl:Class ;
             rdfs:subClassOf :format_2330 ,
                             :format_3245 ;
             :created_in "1.21" ;
             :documentation <http://www.jcamp-dx.org/drafts/JCAMP6_2b%20Draft.pdf> ;
             oboInOwl:hasDefinition "A standardized file format for data exchange in mass spectrometry, initially developed for infrared spectrometry." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:comment "JCAMP-DX is an ASCII based format and therefore not very compact even though it includes standards for file compression." ;
             rdfs:label "JCAMP-DX" ;
             rdfs:seeAlso <https://en.wikipedia.org/wiki/Mass_spectrometry_data_format#cite_note-3> .


