###  http://edamontology.org/data_2526
:data_2526 rdf:type owl:Class ;
           rdfs:subClassOf :data_0006 ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :has_topic ;
                             owl:someValuesFrom :topic_3068
                           ] ;
           :created_in "beta12orEarlier" ;
           oboInOwl:hasDefinition "Data concerning, extracted from, or derived from the analysis of a scientific text (or texts) such as a full text article from a scientific journal." ;
           oboInOwl:hasNarrowSynonym "Article data" ,
                                     "Scientific text data" ;
           oboInOwl:inSubset :bio ,
                             :data ;
           rdfs:comment "This is a broad data type and is used a placeholder for other, more specific types. It is primarily intended to help navigation of EDAM and would not typically be used for annotation. It includes concepts that are best described as scientific text or closely concerned with or derived from text." ;
           rdfs:label "Text data" .


