###  http://edamontology.org/format_3003
:format_3003 rdf:type owl:Class ;
             rdfs:subClassOf :format_2330 ,
                             :format_2919 ;
             :created_in "beta12orEarlier" ;
             :documentation <http://genome.ucsc.edu/FAQ/FAQformat#format1> ;
             :file_extension "bed" ,
                             "bed.gz" ;
             oboInOwl:hasDbXref <http://genome.ucsc.edu/FAQ/FAQformat#format1> ;
             oboInOwl:hasDefinition "Browser Extensible Data (BED) format of sequence annotation track, typically to be displayed in a genome browser." ;
             oboInOwl:inSubset :bio ,
                               :formats ;
             rdfs:comment "BED detail format includes 2 additional columns (http://genome.ucsc.edu/FAQ/FAQformat#format1.7) and BED 15 includes 3 additional columns for experiment scores (http://genomewiki.ucsc.edu/index.php/Microarray_track)." ;
             rdfs:label "BED" .


