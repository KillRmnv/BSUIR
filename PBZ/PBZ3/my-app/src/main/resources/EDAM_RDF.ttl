###  http://edamontology.org/topic_0219
:topic_0219 rdf:type owl:Class ;
            rdfs:subClassOf :topic_3071 ;
            :created_in "beta12orEarlier" ;
            :related_term "Data archive" ,
                          "Data library" ,
                          "Data provenance" ,
                          "Data registry" ,
                          "Data repository" ,
                          "Data storage" ,
                          "Deposition database" ,
                          "Research data archive" ,
                          "Research data repository" ;
            oboInOwl:hasDefinition "Data curation and archival includes the preservation of data in a repository, archive, or a deposition database; and curation of data and metadata, database accessions, annotation, and data provenance." ;
            oboInOwl:hasExactSynonym "Data archival" ,
                                     "Data archiving" ,
                                     "Data curation" ,
                                     "Data preservation" ;
            oboInOwl:hasNarrowSynonym "Database curation" ,
                                      "Research data archiving" ;
            oboInOwl:inSubset :bio ,
                              :events ,
                              :topics ;
            oboInOwl:savedBy "2023-02-24T10:59:23.548411Z, erihje" ,
                             "2024-09-16, bianchini" ,
                             "2024-09-23, Matúš Kalaš" ;
            rdfs:comment "Note that biocuration is a more specific concept than simply curation and archival of bioscientific data." ,
                         "The purpose of data curation and preservation is ensuring permanent access to the data and enabling its future analysis. Enabling reanalysis of the data in unexpected future contexts requires that the data is findable and reusable (see also FAIR data, topic_4012)." ;
            rdfs:label "Data curation and archival" ;
            rdfs:seeAlso <https://en.wikipedia.org/wiki/Data_curation> ,
                         <https://en.wikipedia.org/wiki/Data_preservation> ,
                         <https://en.wikipedia.org/wiki/Research_data_archiving> ;
            skos:editorialNote "TODO: Add Biocuration! Look at and deal with https://en.wikipedia.org/wiki/Digital_curation! And perhaps other from the many concepts within the broad https://en.wikipedia.org/wiki/Digital_preservation (currently in operation_4043)! Probably somehow add Digital library (https://www.wikidata.org/wiki/Q212805) or/and related concepts. Within https://en.wikipedia.org/wiki/Library_science and https://en.wikipedia.org/wiki/Archival_science. Maybe generic archive (https://en.wikipedia.org/wiki/Archive, archiving=https://www.wikidata.org/wiki/Q10418049, and curating=https://www.wikidata.org/wiki/Q63386008)? Preservation is something else, but consider (https://www.wikidata.org/wiki/Q1479406)? And less related, but should we consider https://en.wikipedia.org/wiki/Data_integrity,https://en.wikipedia.org/wiki/File_fixity?" ,
                               "TODO: Add skos:related to Open science (this isn't only science), FAIR data, and Digitalisation (esp. from there to here?). Perhaps more, see a separate editorialNote." ;
            skos:exactMatch <https://www.wikidata.org/wiki/Q15088675> ,
                            <https://www.wikidata.org/wiki/Q48797981> ,
                            <https://www.wikidata.org/wiki/Q65769313> ;
            skos:narrowMatch <https://www.wikidata.org/wiki/Q17155735> ;
            skos:relatedMatch <https://www.wikidata.org/wiki/Q5227240> .


