                                         "Dotplot plotting" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "Dot plots are useful when having not too many (e.g. 20) data points for each category. Example: draw a dotplot of sequence similarities identified from word-matching or character comparison." ;
                rdfs:label "Dot plot plotting" ;
                rdfs:seeAlso <https://en.wikipedia.org/wiki/Dot_plot_(bioinformatics)> .


