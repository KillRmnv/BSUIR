###  http://edamontology.org/operation_3446
:operation_3446 rdf:type owl:Class ;
                rdfs:subClassOf :operation_3443 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_topic ;
                                  owl:someValuesFrom :topic_2229
                                ] ;
