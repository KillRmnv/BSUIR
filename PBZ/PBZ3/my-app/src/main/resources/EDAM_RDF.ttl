            :created_in "1.26" ;
            oboInOwl:hasBroadSynonym "Biogeochemical cycle" ;
            oboInOwl:hasDefinition "The carbon cycle is the biogeochemical pathway of carbon moving through the different parts of the Earth (such as ocean, atmosphere, soil), or eventually another planet." ;
            oboInOwl:inSubset :bio ,
                              :topics ;
            rdfs:comment "Note that the carbon-nitrogen-oxygen (CNO) cycle (https://en.wikipedia.org/wiki/CNO_cycle) is a completely different, thermonuclear reaction in stars." ;
