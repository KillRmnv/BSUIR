                                      "Rational protein design" ;
            oboInOwl:inSubset :bio ,
                              :topics ;
            rdfs:label "Protein folding, stability and design" ;
            rdfs:seeAlso <https://en.wikipedia.org/wiki/Protein_design> ,
                         <https://en.wikipedia.org/wiki/Protein_folding> .


