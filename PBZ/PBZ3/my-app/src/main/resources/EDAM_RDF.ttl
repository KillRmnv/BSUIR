                oboInOwl:hasDefinition "Retrieve information on restriction enzymes or restriction enzyme sites." ;
                oboInOwl:inSubset :obsolete ;
                rdfs:label "Data retrieval (restriction enzyme annotation)" ;
                owl:deprecated "true"^^xsd:boolean .


###  http://edamontology.org/operation_0281
:operation_0281 rdf:type owl:Class ;
                rdfs:subClassOf owl:DeprecatedClass ;
                :created_in "beta12orEarlier" ;
                :obsolete_since "beta13" ;
                :oldParent owl:Thing ;
                oboInOwl:consider :operation_0415 ;
                oboInOwl:hasDefinition "Identify genetic markers in DNA sequences." ;
                oboInOwl:inSubset :obsolete ;
                rdfs:comment "A genetic marker is any DNA sequence of known chromosomal location that is associated with and specific to a particular gene or trait. This includes short sequences surrounding a SNP, Sequence-Tagged Sites (STS) which are well suited for PCR amplification, a longer minisatellites sequence etc." ;
                rdfs:label "Genetic marker identification" ;
                owl:deprecated "true"^^xsd:boolean .


###  http://edamontology.org/operation_0282
:operation_0282 rdf:type owl:Class ;
                rdfs:subClassOf :operation_0283 ,
                                :operation_2520 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_output ;
                                  owl:someValuesFrom :data_1278
                                ] ;
                :created_in "beta12orEarlier" ;
                oboInOwl:hasDefinition "Generate a genetic (linkage) map of a DNA sequence (typically a chromosome) showing the relative positions of genetic markers based on estimation of non-physical distances." ;
                oboInOwl:hasExactSynonym "Functional mapping" ,
                                         "Genetic cartography" ,
                                         "Genetic map construction" ,
                                         "Genetic map generation" ,
                                         "Linkage mapping" ;
                oboInOwl:hasNarrowSynonym "QTL mapping" ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "Mapping involves ordering genetic loci along a chromosome and estimating the physical distance between loci. A genetic map shows the relative (not physical) position of known genes and genetic markers." ,
                             "This includes mapping of the genetic architecture of dynamic complex traits (functional mapping), e.g. by characterisation of the underlying quantitative trait loci (QTLs) or nucleotides (QTNs)." ;
                rdfs:label "Genetic mapping" ;
                rdfs:seeAlso <https://en.wikipedia.org/wiki/Gene_mapping#Gene_mapping> .


###  http://edamontology.org/operation_0283
:operation_0283 rdf:type owl:Class ;
                rdfs:subClassOf :operation_2478 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_output ;
                                  owl:someValuesFrom :data_0927
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :has_topic ;
                                  owl:someValuesFrom :topic_0102
                                ] ;
                :created_in "beta12orEarlier" ;
                oboInOwl:hasDefinition "Analyse genetic linkage." ;
                oboInOwl:inSubset :bio ,
                                  :operations ;
                rdfs:comment "For example, estimate how close two genes are on a chromosome by calculating how often they are transmitted together to an offspring, ascertain whether two genes are linked and parental linkage, calculate linkage map distance etc." ;
                rdfs:label "Linkage analysis" .


###  http://edamontology.org/operation_0284
:operation_0284 rdf:type owl:Class ;
                rdfs:subClassOf :operation_0286 ,
                                :operation_3429 ,
