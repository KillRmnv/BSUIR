# Игнорировать всё, что начинается с точки (кроме .gitignore и разрешённых)
.*
!.gitignore
!.gitattributes
!.github/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Игнорировать большие файлы (>100MB) - для предотвращения случайного коммита
*.psd
*.ai
*.sketch
*.fig

*.ppt
*.pptx
*.xls
*.xlsx
mvnw 
mvnw.cmd  

# Разрешить важные конфиги IDE, если они нужны для команды
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Разрешить README и документацию
!README.md
!README.*
!docs/
!CHANGELOG.md
!LICENSE*

# Разрешить конфигурации сборки (если они не генерируются)
!CMakeLists.txt
!Makefile
!*.pro
!*.gradle
!pom.xml
!requirements.txt
!pyproject.toml
!package.json
!Cargo.toml
